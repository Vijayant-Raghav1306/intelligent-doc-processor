# ─────────────────────────────────────────────────────────────────────────────
# .dockerignore — files excluded from the Docker build context
#
# When you run `docker build .`, Docker sends everything in the current
# directory to the Docker daemon as the "build context". Large directories
# (like venv/) would make every build slow and bloated.
#
# This file works exactly like .gitignore but for Docker builds.
# ─────────────────────────────────────────────────────────────────────────────

# ── Python virtual environment ────────────────────────────────────────────────
# CRITICAL: venv/ is hundreds of MB. Never send it to Docker.
# Docker installs its own packages from requirements.txt inside the image.
venv/
.venv/
env/
ENV/

# ── Python bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ── Git metadata ──────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Secrets (NEVER send these into an image) ──────────────────────────────────
.env
.env.local
.env.*.local

# ── Runtime directories (ephemeral — created fresh on start) ─────────────────
uploads/
outputs/

# ── Test artifacts ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE settings ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Documentation (not needed at runtime) ─────────────────────────────────────
README.md
explain.txt

# ── Build configs (not needed inside the container) ───────────────────────────
render.yaml
build.sh
build_render.sh
Dockerfile
