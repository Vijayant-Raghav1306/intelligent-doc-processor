# ─────────────────────────────────────────────────────────────────────────────
# Intelligent Document Processor — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored (never commit secrets).
# This .env.example file IS committed — it's a template, not a secret.
# ─────────────────────────────────────────────────────────────────────────────


# ── Tesseract OCR ─────────────────────────────────────────────────────────────
# Path to the tesseract binary.
#
# Linux / Render / Docker (after apt-get install tesseract-ocr):
#   TESSERACT_CMD=tesseract
#
# macOS (after brew install tesseract):
#   TESSERACT_CMD=tesseract
#
# Windows (adjust to your actual install path):
#   TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
#   TESSERACT_CMD=C:\Users\YourName\AppData\Local\Programs\Tesseract-OCR\tesseract.EXE
TESSERACT_CMD=tesseract


# ── spaCy NLP Model ───────────────────────────────────────────────────────────
# Which spaCy model to load at startup.
#
# Options (install with `python -m spacy download <model>`):
#   en_core_web_sm   — 12 MB,  fast,  good accuracy  (default)
#   en_core_web_md   — 43 MB,  word vectors, better similarity
#   en_core_web_lg   — 587 MB, best vectors
#   en_core_web_trf  — 440 MB, transformer-based, highest NER accuracy
#
# Set to empty string to disable NLP entirely (regex-only mode):
#   SPACY_MODEL=
SPACY_MODEL=en_core_web_sm


# ── File Limits ───────────────────────────────────────────────────────────────
# Maximum allowed upload size in megabytes.
MAX_FILE_SIZE_MB=10


# ── Storage Directories ───────────────────────────────────────────────────────
# Relative to wherever you launch the server from.
# Created automatically at startup if they don't exist.
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs


# ── App Identity ──────────────────────────────────────────────────────────────
APP_NAME=Intelligent Doc Processor
