# ─────────────────────────────────────────────────────────
# .env.example — copy to .env.local and fill in your values
#
#   cp .env.example .env.local
#
# Vite only exposes env vars that start with VITE_ to the browser.
# Never put secrets here — this file is committed to git.
# ─────────────────────────────────────────────────────────

# URL of your FastAPI backend.
#
# Local development:
#   Leave this commented out. The vite.config.js proxy handles routing
#   so requests go to http://localhost:8000 automatically.
#
# Production (Vercel + Render):
#   Set this to your Render service URL, e.g.:
#   VITE_API_URL=https://intelligent-doc-processor.onrender.com
VITE_API_URL=
